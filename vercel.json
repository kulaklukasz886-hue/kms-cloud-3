<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>KMS — Kreator Rozkroju TEST 0.8 — INTEGRACJA KMS</title>
<style>
:root{
  --navy:#173b60;--blue:#2f6fa5;--blue2:#dceaf6;--bg:#f4f7fa;--card:#fff;
  --line:#c7d5e2;--text:#1f2b36;--muted:#647586;--green:#def3e4;
  --yellow:#fff3c9;--red:#ffe3e3;--orange:#ffedd5;
}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--text);font-family:Arial,Helvetica,sans-serif}
header{background:linear-gradient(135deg,var(--navy),var(--blue));color:#fff;padding:20px 18px}
header h1{margin:0;font-size:25px} header p{margin:7px 0 0;opacity:.93}
.wrap{max-width:1720px;margin:0 auto;padding:16px}
.panel,.item-card,.material-result{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:15px;margin-bottom:14px;box-shadow:0 2px 8px rgba(20,40,60,.05)}
h2,h3,h4{margin-top:0}.toolbar,.status-line{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
button{border:0;border-radius:9px;padding:10px 14px;font:inherit;font-weight:700;cursor:pointer}
button.primary{background:var(--blue);color:#fff}button.secondary{background:#e7eef5;color:#21384e}
button.danger{background:#ffe4e4;color:#8e2525}button.small{padding:7px 10px;font-size:12px}
button:disabled{opacity:.45;cursor:not-allowed}
label{font-size:12px;font-weight:700;color:#52606d;display:block;margin-bottom:5px}
input,select,textarea{width:100%;border:1px solid #b8c7d5;border-radius:8px;padding:9px;background:#fff;font:inherit}
input[readonly]{background:#eef3f7;font-weight:700}input[type=checkbox]{width:auto}
.meta-grid{display:grid;grid-template-columns:repeat(6,minmax(150px,1fr));gap:10px}
.constants{display:grid;grid-template-columns:repeat(5,minmax(170px,1fr));gap:10px}
.const{background:#edf5fb;border:1px solid #b9d2e6;border-radius:11px;padding:11px}.const b{display:block;font-size:19px;margin-top:4px}
.badge{display:inline-block;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:700}.green{background:var(--green);color:#25613a}.yellow{background:var(--yellow);color:#765900}.red{background:var(--red);color:#8b2525}.blueb{background:#dcecff;color:#1d5688}.orange{background:var(--orange);color:#8a4b08}
.item-head{display:grid;grid-template-columns:1.15fr 2.2fr .7fr .9fr auto;gap:9px;align-items:end}
.item-grid{display:grid;grid-template-columns:repeat(8,minmax(105px,1fr));gap:9px;margin-top:10px}
.item-services{display:grid;grid-template-columns:repeat(7,minmax(120px,1fr));gap:9px;margin-top:10px;padding-top:10px;border-top:1px dashed var(--line)}
.inline-check{display:flex;gap:7px;align-items:center;padding:9px;background:#f3f6f9;border-radius:8px;min-height:40px}.inline-check label{margin:0}
.edge-box{background:#f8fafc;border:1px solid #d5e0e9;border-radius:10px;padding:9px}.edge-box strong{font-size:12px}.edge-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-top:7px}
.catalog-note,.note{font-size:12px;color:var(--muted)}
.kpis{display:grid;grid-template-columns:repeat(8,minmax(135px,1fr));gap:10px}.metric{background:#f5f8fb;border:1px solid var(--line);border-radius:10px;padding:11px}.metric b{display:block;font-size:20px;margin-top:5px}
.ok-box{background:#ecf8ef;border-left:5px solid #4b9b62;padding:12px;border-radius:8px}.warn-box{background:#fff9df;border-left:5px solid #e0b100;padding:12px;border-radius:8px}.error-box{background:#fff0f0;border-left:5px solid #c94b4b;padding:12px;border-radius:8px}
table{width:100%;border-collapse:collapse;margin-top:10px}th,td{border:1px solid #cbd7e3;padding:8px;text-align:left;font-size:12px}th{background:#dceaf6;position:sticky;top:0}.scroll{overflow:auto;max-height:540px}
.board-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:12px}.board-card{border:2px solid #6d8daa;border-radius:12px;padding:10px;background:#fff}.board-card h4{margin:0 0 4px}.board-meta{font-size:12px;color:var(--muted);margin-bottom:7px}.board-svg{display:block;width:100%;height:auto;background:#f7fafc;border-radius:8px}
.material-result{border-width:2px}.material-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;flex-wrap:wrap}
.summary-grid{display:grid;grid-template-columns:repeat(5,minmax(145px,1fr));gap:9px;margin:10px 0}.summary-cell{background:#f6f9fb;border:1px solid var(--line);border-radius:9px;padding:9px}.summary-cell b{display:block;margin-top:4px}
.hidden{display:none!important}
.service-price-input{min-width:120px;text-align:right}.price-missing{background:#fff0f0!important;border-color:#c94b4b!important}.price-ok{background:#ecf8ef!important;border-color:#4b9b62!important}
.modal-overlay{position:fixed;inset:0;z-index:10000;background:rgba(15,30,45,.68);display:none;align-items:center;justify-content:center;padding:18px}.modal-overlay.open{display:flex}.modal-card{width:min(720px,100%);max-height:88vh;overflow:auto;background:#fff;border-radius:16px;border:3px solid #c94b4b;box-shadow:0 20px 70px rgba(0,0,0,.35);padding:20px}.modal-card h2{color:#8b2525;margin-bottom:8px}.modal-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:16px}
@media(max-width:1200px){.meta-grid{grid-template-columns:repeat(3,1fr)}.constants{grid-template-columns:repeat(3,1fr)}.item-grid{grid-template-columns:repeat(4,1fr)}.item-services{grid-template-columns:repeat(4,1fr)}.kpis{grid-template-columns:repeat(4,1fr)}}
@media(max-width:760px){.meta-grid,.constants,.item-head,.item-grid,.item-services,.kpis,.summary-grid{grid-template-columns:1fr 1fr}.edge-grid{grid-template-columns:1fr 1fr}.board-grid{grid-template-columns:1fr}}
@media(max-width:520px){.meta-grid,.constants,.item-head,.item-grid,.item-services,.kpis,.summary-grid{grid-template-columns:1fr}}
@media print{body{background:#fff}.no-print{display:none!important}.panel,.item-card,.material-result{box-shadow:none;break-inside:avoid}.wrap{max-width:none;padding:0}header{background:#fff;color:#000;border-bottom:2px solid #000}.scroll{max-height:none;overflow:visible}th{position:static}}
</style>
</head>
<body>
<header><div class="wrap" style="padding:0"><h1>KMS — Kreator Rozkroju</h1><p>TEST 0.8 • Wynik Etapu 2 → optymalizacja 2000+ elementów → liczba płyt → odpady do modułu KMS</p></div></header>
<div class="wrap">
  <section class="panel">
    <div class="meta-grid">
      <div><label>Numer zlecenia</label><input id="orderNo" value="TEST-001"></div>
      <div><label>Klient</label><input id="customer" value="TEST KMS"></div>
      <div><label>Nazwa zamówienia</label><input id="orderName" value="ROZKRÓJ TESTOWY"></div>
      <div><label>Data</label><input id="orderDate" type="date"></div>
      <div><label>Operator</label><input id="operator" value="ŁUKASZ"></div>
      <div><label>Status</label><input value="WERSJA TESTOWA" readonly></div>
    </div>
  </section>

  <section class="panel">
    <h2>Stałe technologiczne rozkroju</h2>
    <div class="constants">
      <div class="const">Pełna płyta EGGER<b>2800 × 2070 mm</b></div>
      <div class="const">Pole robocze<b>2770 × 2040 mm</b></div>
      <div class="const">Rzaz poziomy<b>4,4 mm</b></div>
      <div class="const">Rzaz pionowy<b>4,4 mm</b></div>
      <div class="const">Wąskie elementy ≤ 100 mm<b>W miarę możliwości środek płyty</b></div>
      <div class="const">Płyta obrotowa<b>Pasy wzdłuż 2800 mm</b></div>
      <div class="const">Priorytet optymalizacji<b>Największy użyteczny odpad</b></div>
      <div class="const">Wymiar odpadu na pile<b>Z pełnej płyty 2800 × 2070 — bez brzegowania odpadu</b></div>
      <div class="const">Przepływ modułów<b>Rozkrój → planowany odpad → potwierdzenie cięcia → DO WYKORZYSTANIA</b></div>
      <div class="const">Elementy 36 mm<b>2 fizyczne formatki z Etapu 2 — suma m²</b></div>
      <div class="const">Elementy 28 mm<b>2 fizyczne formatki z Etapu 2 — suma m²</b></div>
      <div class="const">Wydajność optymalizacji<b>Minimum 2000 elementów różnych wymiarów jednego materiału</b></div>
    </div>
    <p class="note">Pole robocze 2770 × 2040 mm służy do układania formatek, ale odpad jest liczony jako fizyczny kawałek pozostały z pełnej płyty 2800 × 2070 mm. Odpadu nie brzegujemy automatycznie: pełny odpad boczny zachowuje długość 2800 mm. Rzaz 4,4 mm jest odejmowany w miejscu rzeczywistego oddzielenia odpadu. Kreator tworzy planowane rekordy odpadów i przygotowuje je do automatycznego przekazania do modułu Odpady. Po potwierdzeniu wykonania cięcia rekord zmienia status z PLANOWANY na DO WYKORZYSTANIA. Dzięki temu wirtualny magazyn nie otrzymuje odpadu, który istnieje tylko na niezrealizowanym planie.</p>
  </section>

  <section class="panel no-print">
    <div class="toolbar">
      <button class="primary" id="addItem">+ Dodaj formatkę</button>
      <button class="secondary" id="loadExample">Wczytaj przykład</button>
      <button class="secondary" id="loadStress2000">TEST 2000 — jeden kolor</button>
      <button class="secondary" id="importCatalog">Importuj katalog JSON</button>
      <button class="secondary" id="downloadCatalogTemplate">Szablon katalogu JSON</button>
      <button class="secondary" id="saveLocal">Zapisz test</button>
      <button class="secondary" id="loadLocal">Wczytaj zapis</button>
      <button class="primary" id="optimize">OBLICZ I OPTYMALIZUJ</button>
      <button class="secondary" id="exportJson">Eksport danych KMS JSON</button>
      <button class="secondary" id="exportWasteJson">Eksport odpadów JSON</button>
      <button class="secondary" onclick="window.print()">Drukuj / PDF</button>
      <button class="danger" id="resetAll">Wyczyść</button>
    </div>
    <input id="catalogFile" type="file" accept="application/json,.json" class="hidden">
    <div class="status-line" style="margin-top:10px">
      <span class="badge blueb" id="catalogCount">Katalog testowy: 0 produktów</span>
      <span class="badge yellow">Materiał można wybrać wyłącznie z katalogu</span>
      <span class="badge green">Grubość przechowywana osobno od symbolu</span>
      <span class="badge blueb">ODPADY: automatyczny pakiet integracyjny</span>
      <span class="badge blueb" id="engineStatus">Silnik gotowy: 0 elementów</span>
    </div>
  </section>

  <section class="panel" id="servicePricePanel">
    <h2>Katalog cen usług — administrator</h2>
    <p class="note">Cena jest wymagana tylko dla usługi, której ilość w danym zamówieniu jest większa od zera. Brak ceny blokuje finalną proformę i eksport.</p>
    <div class="scroll"><table><thead><tr><th>Kod</th><th>Usługa</th><th>Jednostka</th><th>Cena netto</th><th>Status</th></tr></thead><tbody id="servicePriceTable"></tbody></table></div>
  </section>

  <section class="panel">
    <h2>Formatki i operacje</h2>
    <div id="items"></div>
  </section>

  <section class="panel" id="validationPanel">
    <h2>Kontrola danych</h2>
    <div id="validation"><div class="warn-box">Wprowadź formatki i uruchom optymalizację.</div></div>
  </section>

  <section class="panel" id="resultPanel">
    <h2>Wyniki do proformy i zamówień</h2>
    <div class="kpis">
      <div class="metric">M² fizycznych formatek z Etapu 2<b id="kM2">0,000</b></div>
      <div class="metric">Płyty do zamówienia<b id="kBoards">0</b></div>
      <div class="metric">Elementy przetworzone<b id="kPieces">0</b></div>
      <div class="metric">Czas optymalizacji<b id="kTime">0 ms</b></div>
      <div class="metric">PCV 1 MM<b id="kEdge1">0,000 mb</b></div>
      <div class="metric">PCV 2 MM<b id="kEdge2">0,000 mb</b></div>
      <div class="metric">PCV 43/2 MM<b id="kEdge43">0,000 mb</b></div>
      <div class="metric">36 MM — m² fizycznych elementów<b id="k36">0,000 m²</b></div>
      <div class="metric">28 MM — m² fizycznych elementów<b id="k28">0,000 m²</b></div>
      <div class="metric">Rozcinanie lameli<b id="kLamella">0 szt.</b></div>
      <div class="metric">Cięcie ze słoja<b id="kGrain">0 frontów</b></div>
      <div class="metric">Planowane odpady<b id="kWasteCount">0 szt.</b></div>
      <div class="metric">Powierzchnia odpadów<b id="kWasteM2">0,000 m²</b></div>
    </div>
  </section>

  <section class="panel">
    <h2>Usługi — dane wynikowe do proformy</h2>
    <div class="scroll"><table><thead><tr><th>Kod</th><th>Usługa</th><th>Ilość</th><th>Jednostka</th><th>Cena netto</th><th>Wartość netto</th><th>Status</th><th>Uwagi</th></tr></thead><tbody id="proformaTable"></tbody></table></div>
  </section>

  <section class="panel">
    <h2>Zamówienie materiałów do dostawców</h2>
    <div class="scroll"><table><thead><tr><th>ID katalogu</th><th>Materiał</th><th>Grubość</th><th>Format</th><th>Pole robocze</th><th>Obrotowość</th><th>M² produkcyjne</th><th>Liczba płyt</th><th>Wykorzystanie</th><th>Status ceny</th></tr></thead><tbody id="supplierTable"></tbody></table></div>
  </section>

  <section class="panel">
    <h2>Podgląd rozkroju</h2>
    <div id="layouts"><div class="note">Brak wyników.</div></div>
  </section>


  <section class="panel">
    <h2>Odpady do wykorzystania — automatyczny przepływ KMS</h2>
    <div class="ok-box"><b>Etap 2 tworzy plan odpadu.</b> Po potwierdzeniu wykonania cięcia KMS ma automatycznie zmienić status na <b>DO WYKORZYSTANIA</b> i zapisać rekord w module <b>Odpady → Płyty → Cięcie</b>.</div>
    <div class="scroll"><table><thead><tr><th>ID odpadu</th><th>Zlecenie</th><th>Materiał</th><th>Grubość</th><th>Płyta</th><th>Typ odpadu</th><th>Wymiar fizyczny</th><th>M²</th><th>Obrotowość</th><th>Status teraz</th><th>Status po cięciu</th></tr></thead><tbody id="wasteTable"></tbody></table></div>
  </section>

  <section class="panel">
    <h2>Rozpiska elementów produkcyjnych</h2>
    <div class="scroll"><table><thead><tr><th>Element</th><th>Materiał</th><th>Grubość</th><th>Wymiar gotowy</th><th>Technologia</th><th>Wymiar do rozkroju</th><th>Ilość produkcyjna</th><th>Płyta</th><th>Pozycja</th><th>Obrót</th></tr></thead><tbody id="piecesTable"></tbody></table></div>
  </section>
</div>
<div id="priceModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="priceModalTitle">
  <div class="modal-card">
    <h2 id="priceModalTitle">PROSZĘ PRZYPISAĆ CENĘ USŁUGI</h2>
    <p>W zamówieniu występują usługi bez przypisanej ceny. Rozkrój może być oglądany, ale finalna proforma i eksport pozostają zablokowane.</p>
    <div id="priceModalList" class="error-box"></div>
    <div class="modal-actions"><button id="closePriceModal" class="primary" type="button">Przejdź do cen usług</button></div>
  </div>
</div>
<script>
const BOARD_FULL_L=2800, BOARD_FULL_W=2070;
const BOARD_WORK_L=2770, BOARD_WORK_W=2040;
const KERF=4.4;
const NARROW_ELEMENT_MAX_MM=100;
const STRIP_OPTIMIZATION=true;
const REUSABLE_OFFCUT_PRIORITY=true;
const PHYSICAL_WASTE_FROM_FULL_BOARD=true;
const AUTO_WASTE_MODULE_TRANSFER=true;
const WASTE_SOURCE_MODULE="KREATOR_ROZKROJU_ETAP_2";
const WASTE_TARGET_MODULE="ODPADY_PLYTY_CIECIE";
const WASTE_PLANNED_STATUS="PLANOWANY";
const WASTE_AVAILABLE_STATUS="DO WYKORZYSTANIA";
const MAX_BOARD_PREVIEW=24;
const MAX_PIECE_PREVIEW=500;
const MAX_WASTE_PREVIEW=500;
const EDGE_TYPES=["BRAK","1MM","2MM","43/2MM"];
const SERVICE_DEFS=[
 {code:"FORMATKI_STANDARD_M2",name:"Cięcie formatek standardowych",unit:"m²"},
 {code:"PCV_1MM",name:"Oklejanie PCV 1 MM",unit:"mb"},
 {code:"PCV_2MM",name:"Oklejanie PCV 2 MM",unit:"mb"},
 {code:"PCV_43_2MM",name:"Oklejanie PCV 43/2 MM",unit:"mb"},
 {code:"FREZ_HDF_MALY",name:"Frez pod HDF — mały do 1 m",unit:"szt."},
 {code:"FREZ_HDF_DUZY",name:"Frez pod HDF — duży powyżej 1 m",unit:"szt."},
 {code:"FREZ_LED_MALY",name:"Frez LED — mały do 1 m",unit:"szt."},
 {code:"FREZ_LED_DUZY",name:"Frez LED — duży powyżej 1 m",unit:"szt."},
 {code:"FORMATKI_36MM_M2",name:"Cięcie fizycznych formatek do elementów 36 MM",unit:"m²"},
 {code:"KLEJENIE_36MM_M2",name:"Klejenie elementów 36 MM",unit:"m²"},
 {code:"FORMATKI_28MM_M2",name:"Cięcie fizycznych formatek do elementów 28 MM",unit:"m²"},
 {code:"KLEJENIE_28MM_M2",name:"Klejenie elementów 28 MM",unit:"m²"},
 {code:"ROZCINANIE_LAMELI",name:"Rozcinanie lameli",unit:"szt."},
 {code:"CIECIE_ZE_SLOJA",name:"Cięcie ze słoja",unit:"front"}
];
let servicePrices=Object.fromEntries(SERVICE_DEFS.map(s=>[s.code,null]));

const defaultCatalog=[
 {id:"EGGER-W960-ST7-18",manufacturer:"EGGER",symbol:"W960",structure:"ST7",name:"Biały klasyczny",thickness:18,length:2800,width:2070,workLength:2770,workWidth:2040,rotatable:true,priceStatus:"NIEPOTWIERDZONA"},
 {id:"EGGER-U999-ST7-18",manufacturer:"EGGER",symbol:"U999",structure:"ST7",name:"Czarny",thickness:18,length:2800,width:2070,workLength:2770,workWidth:2040,rotatable:true,priceStatus:"NIEPOTWIERDZONA"},
 {id:"EGGER-H1385-ST40-18",manufacturer:"EGGER",symbol:"H1385",structure:"ST40",name:"Dąb Casella naturalny",thickness:18,length:2800,width:2070,workLength:2770,workWidth:2040,rotatable:false,priceStatus:"NIEPOTWIERDZONA"},
 {id:"EGGER-H3730-ST10-18",manufacturer:"EGGER",symbol:"H3730",structure:"ST10",name:"Hikora naturalna",thickness:18,length:2800,width:2070,workLength:2770,workWidth:2040,rotatable:false,priceStatus:"NIEPOTWIERDZONA"}
];
let catalog=JSON.parse(JSON.stringify(defaultCatalog));
let state={items:[],lastResult:null};
function uid(){return crypto.randomUUID?crypto.randomUUID():`kms-${Date.now()}-${Math.random().toString(16).slice(2)}`}
function n(v,f=0){const x=Number(v);return Number.isFinite(x)?x:f}
function fmt(v,d=3){return n(v).toLocaleString("pl-PL",{minimumFractionDigits:d,maximumFractionDigits:d})}
function esc(v){return String(v??"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[m]))}
function productLabel(p){return `${p.manufacturer} ${p.symbol} ${p.structure} | ${p.thickness} mm | ${p.name}`}
function getProduct(id){return catalog.find(p=>p.id===id)||null}
function emptyItem(){return {id:uid(),name:"ELEMENT",productId:catalog[0]?.id||"",length:720,width:396,qty:1,technology:"STANDARD",gluePair:"",isFront:false,edges:{top:"BRAK",bottom:"BRAK",left:"BRAK",right:"BRAK"},hdfLength:0,hdfQty:0,ledLength:0,ledQty:0,lamellaCuts:0}}
function productOptions(selected){return `<option value="">— WYBIERZ Z KATALOGU —</option>`+catalog.map(p=>`<option value="${esc(p.id)}" ${p.id===selected?"selected":""}>${esc(productLabel(p))}</option>`).join("")}
function edgeOptions(selected){return EDGE_TYPES.map(x=>`<option ${x===selected?"selected":""}>${x}</option>`).join("")}
function renderItems(){
 const host=document.getElementById("items");
 if(!state.items.length){host.innerHTML='<div class="warn-box">Brak formatek. Dodaj pierwszą pozycję.</div>';return}
 host.innerHTML=state.items.map((it,i)=>{
  const p=getProduct(it.productId);
  return `<div class="item-card">
    <div class="item-head">
      <div><label>Nazwa elementu</label><input data-id="${it.id}" data-field="name" value="${esc(it.name)}"></div>
      <div><label>Produkt z Katalogu KMS</label><select data-id="${it.id}" data-field="productId">${productOptions(it.productId)}</select></div>
      <div><label>Ilość</label><input type="number" min="1" data-id="${it.id}" data-field="qty" value="${it.qty}"></div>
      <div><label>Technologia</label><select data-id="${it.id}" data-field="technology"><option ${it.technology==="STANDARD"?"selected":""}>STANDARD</option><option ${it.technology==="36MM"?"selected":""}>36MM</option><option ${it.technology==="28MM"?"selected":""}>28MM</option></select></div>
      <div class="toolbar no-print"><button class="secondary small" data-action="duplicate" data-id="${it.id}">Duplikuj</button><button class="danger small" data-action="remove" data-id="${it.id}">Usuń</button></div>
    </div>
    <div class="item-grid">
      <div><label>DŁUGOŚĆ [mm]</label><input type="number" min="1" data-id="${it.id}" data-field="length" value="${it.length}"></div>
      <div><label>SZEROKOŚĆ [mm]</label><input type="number" min="1" data-id="${it.id}" data-field="width" value="${it.width}"></div>
      <div><label>GRUBOŚĆ</label><input value="${p?esc(p.thickness):"—"} mm" readonly></div>
      <div><label>SYMBOL</label><input value="${p?esc(`${p.symbol} ${p.structure}`):"—"}" readonly></div>
      <div><label>FORMAT PRODUKTU</label><input value="${p?`${p.length} × ${p.width}`:"—"}" readonly></div>
