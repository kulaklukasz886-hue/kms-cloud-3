function compactHostResult(){
 if(!state.lastResult)return null;
 return {
  version:"KMS_CUTTING_RESULT_0.8",
  createdAt:state.lastResult.createdAt,
  order:{orderNo:orderNo.value,customer:customer.value,orderName:orderName.value,date:orderDate.value,operator:operator.value},
  metrics:JSON.parse(JSON.stringify(state.lastResult.metrics)),
  optimizationMs:state.lastResult.optimizationMs,
  priceComplete:state.lastResult.priceComplete,
  missingServicePrices:JSON.parse(JSON.stringify(state.lastResult.missingServicePrices||[])),
  supplierOrder:state.lastResult.groups.map(g=>({
   catalogProductId:g.product.id,manufacturer:g.product.manufacturer,material:`${g.product.symbol} ${g.product.structure}`.trim(),
   thickness:g.product.thickness,fullFormat:[g.product.length,g.product.width],workArea:[g.product.workLength,g.product.workWidth],
   rotatable:g.product.rotatable,boards:g.bins.length,productionM2:g.pieces.reduce((sum,p)=>sum+p.length*p.width/1e6,0)
  })),
  wasteModuleTransfer:JSON.parse(JSON.stringify(state.lastResult.wasteModuleTransfer||[])),
  processedPieces:state.lastResult.metrics.pieces,
  boards:state.lastResult.metrics.boards
 };
}
function emitHost(type,payload){
 const detail={source:"KMS_CUTTING_MODULE",type,payload};
 window.dispatchEvent(new CustomEvent(type,{detail}));
 if(window.parent&&window.parent!==window)window.parent.postMessage(detail,"*");
}
function emitHostResult(){const result=compactHostResult();if(result)emitHost("kms:cutting:result",result)}
function loadStage2Payload(input){
 const data=input||{};
 const products=Array.isArray(data.catalog)?data.catalog:[];
 const rows=Array.isArray(data.items)?data.items:[];
 if(!products.length)throw new Error("Brak katalogu materiałów z Etapu 2.");
 catalog=products.map(p=>({
  id:String(p.id),manufacturer:String(p.manufacturer||"KMS"),symbol:String(p.symbol||p.material||"MATERIAŁ"),structure:String(p.structure||""),
  name:String(p.name||p.material||"Materiał z Etapu 2"),thickness:n(p.thickness,18),length:n(p.length,BOARD_FULL_L),width:n(p.width,BOARD_FULL_W),
  workLength:n(p.workLength,n(p.length,BOARD_FULL_L)-30),workWidth:n(p.workWidth,n(p.width,BOARD_FULL_W)-30),rotatable:!!p.rotatable,
  priceStatus:String(p.priceStatus||"KATALOG KMS")
 }));
 state.items=rows.map((it,index)=>({
  id:uid(),name:String(it.name||it.element||`ELEMENT ${index+1}`),productId:String(it.productId||products[0].id),
  length:n(it.length),width:n(it.width),qty:Math.max(1,n(it.qty,1)),technology:["36MM","28MM"].includes(String(it.technology||it.rule))?String(it.technology||it.rule):"STANDARD",
  gluePair:String(it.gluePair||""),isFront:!!it.isFront,
  edges:{top:String(it.edges?.top||"BRAK"),bottom:String(it.edges?.bottom||"BRAK"),left:String(it.edges?.left||"BRAK"),right:String(it.edges?.right||"BRAK")},
  hdfLength:n(it.hdfLength),hdfQty:n(it.hdfQty),ledLength:n(it.ledLength),ledQty:n(it.ledQty),lamellaCuts:n(it.lamellaCuts)
 }));
 const meta=data.order||{};
 orderNo.value=String(meta.orderNo||"");customer.value=String(meta.customer||meta.client||"");orderName.value=String(meta.orderName||"ROZKRÓJ Z ETAPU 2");
 orderDate.value=String(meta.date||new Date().toISOString().slice(0,10));operator.value=String(meta.operator||"KMS");
 servicePrices={...servicePrices,...(data.servicePrices||{})};state.lastResult=null;
 updateCatalogCount();renderServicePrices();renderItems();clearResults();
 requestAnimationFrame(()=>optimize(false));
 return true;
}
window.KMSCuttingModule={
 version:"0.8-integrated-test",loadStage2Payload,getResult:()=>compactHostResult(),getPayload:()=>payload(),optimize:()=>optimize(false),clear:()=>{state={items:[],lastResult:null};renderItems();clearResults()}
};
window.addEventListener("message",event=>{
 const msg=event.data||{};
 if(msg.source==="KMS_HOST"&&msg.type==="kms:cutting:load-stage2"){
  try{loadStage2Payload(msg.payload);emitHost("kms:cutting:loaded",{ok:true,items:state.items.length})}
  catch(error){emitHost("kms:cutting:error",{message:error.message||String(error)})}
 }
});
document.getElementById("closePriceModal").onclick=()=>{hidePriceModal();document.getElementById("servicePricePanel").scrollIntoView({behavior:"smooth",block:"start"})};
orderDate.value=new Date().toISOString().slice(0,10);updateCatalogCount();renderServicePrices();
if(new URLSearchParams(location.search).get("embedded")==="1"){state={items:[],lastResult:null};renderItems();clearResults()}else example();
setTimeout(()=>emitHost("kms:cutting:ready",{version:"0.8-integrated-test"}),0);
</script>
</body>
</html>
