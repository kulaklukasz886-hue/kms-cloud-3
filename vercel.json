      <div><label>OBROTOWOŚĆ</label><input value="${p?(p.rotatable?"OBROTOWA":"NIEOBROTOWA"):"—"}" readonly></div>
      <div><label>PARA KLEJENIA</label><input data-id="${it.id}" data-field="gluePair" value="${esc(it.gluePair||"")}" placeholder="np. KLEJ-01" ${it.technology==="STANDARD"?"disabled":""}></div>
      <div class="inline-check"><input type="checkbox" data-id="${it.id}" data-field="isFront" ${it.isFront?"checked":""}><label>FRONT — cięcie ze słoja</label></div>
    </div>
    <div class="edge-box" style="margin-top:10px"><strong>Oklejanie krawędzi</strong><div class="edge-grid">
      <div><label>GÓRA (${it.width} mm)</label><select data-id="${it.id}" data-edge="top">${edgeOptions(it.edges.top)}</select></div>
      <div><label>DÓŁ (${it.width} mm)</label><select data-id="${it.id}" data-edge="bottom">${edgeOptions(it.edges.bottom)}</select></div>
      <div><label>LEWA (${it.length} mm)</label><select data-id="${it.id}" data-edge="left">${edgeOptions(it.edges.left)}</select></div>
      <div><label>PRAWA (${it.length} mm)</label><select data-id="${it.id}" data-edge="right">${edgeOptions(it.edges.right)}</select></div>
    </div></div>
    <div class="item-services">
      <div><label>Frez HDF — długość [mm]</label><input type="number" min="0" data-id="${it.id}" data-field="hdfLength" value="${it.hdfLength}"></div>
      <div><label>Frez HDF — ilość / element</label><input type="number" min="0" data-id="${it.id}" data-field="hdfQty" value="${it.hdfQty}"></div>
      <div><label>Frez LED — długość [mm]</label><input type="number" min="0" data-id="${it.id}" data-field="ledLength" value="${it.ledLength}"></div>
      <div><label>Frez LED — ilość / element</label><input type="number" min="0" data-id="${it.id}" data-field="ledQty" value="${it.ledQty}"></div>
      <div><label>Rozcinanie lameli / element</label><input type="number" min="0" data-id="${it.id}" data-field="lamellaCuts" value="${it.lamellaCuts}"></div>
      <div><label>M² fizyczne z Etapu 2</label><input value="${fmt(it.length*it.width*it.qty/1e6)}" readonly></div>
      <div><label>Uwagi technologiczne</label><input value="${it.technology==="36MM"?"INFO 36MM; fizyczne elementy z Etapu 2; powierzchnia sumowana; bez ponownego ×2":it.technology==="28MM"?"INFO 28MM; fizyczne elementy z Etapu 2; powierzchnia sumowana; bez ponownego ×2":"STANDARD"}" readonly></div>
    </div>
  </div>`}).join("");
}
function applyTechnologyEdgeRule(item){
 if(item.technology==="36MM"||item.technology==="28MM"){
  Object.keys(item.edges).forEach(k=>{if(item.edges[k]!=="BRAK")item.edges[k]="43/2MM"})
 }else item.gluePair="";
}
function validateCatalogProduct(p){return p&&p.id&&p.symbol&&p.structure&&n(p.thickness)>0&&n(p.length)>0&&n(p.width)>0&&n(p.workLength)>0&&n(p.workWidth)>0}
function validate(){
 const errors=[],warnings=[],glueGroups=new Map();
 if(!state.items.length)errors.push("Brak formatek w zamówieniu.");
 state.items.forEach((it,idx)=>{
  const no=idx+1,p=getProduct(it.productId);
  if(!p)errors.push(`Pozycja ${no}: nie wybrano produktu z Katalogu KMS.`);
  else if(!validateCatalogProduct(p))errors.push(`Pozycja ${no}: produkt katalogowy ma niepełne dane.`);
  if(n(it.length)<=0||n(it.width)<=0)errors.push(`Pozycja ${no}: długość i szerokość muszą być większe od zera.`);
  if(n(it.qty)<1)errors.push(`Pozycja ${no}: ilość musi wynosić co najmniej 1.`);
  if(p){
    const L=n(it.length),W=n(it.width),fitsNormal=L<=p.workLength&&W<=p.workWidth,fitsRot=p.rotatable&&W<=p.workLength&&L<=p.workWidth;
    if(!(fitsNormal||fitsRot))errors.push(`Pozycja ${no} (${it.name}): fizyczny wymiar z Etapu 2 ${L} × ${W} mm przekracza pole robocze ${p.workLength} × ${p.workWidth} mm. WYMAGANY PODZIAŁ ELEMENTU.`);
    if(!fitsNormal&&fitsRot)warnings.push(`Pozycja ${no}: element zmieści się wyłącznie po obrocie.`);
    if(p.priceStatus!=="POTWIERDZONA PRZEZ ADMINISTRATORA")warnings.push(`Pozycja ${no}: cena produktu ${p.symbol} ${p.structure} jest niepotwierdzona.`);
  }
  if(it.technology==="36MM"||it.technology==="28MM"){
    if(Object.values(it.edges).some(x=>x==="1MM"||x==="2MM"))errors.push(`Pozycja ${no}: dla technologii ${it.technology} wskazane krawędzie muszą używać PCV 43/2MM.`);
    const pair=(it.gluePair||"").trim();
    if(!pair)errors.push(`Pozycja ${no}: element ${it.technology} wymaga identyfikatora pary klejenia.`);
    else{
      if(!glueGroups.has(pair))glueGroups.set(pair,{technology:it.technology,qty:0,rows:[]});
      const g=glueGroups.get(pair);g.qty+=n(it.qty);g.rows.push(no);
      if(g.technology!==it.technology)errors.push(`Para klejenia ${pair}: nie można łączyć technologii ${g.technology} i ${it.technology}.`);
    }
  }
 });
 glueGroups.forEach((g,pair)=>{
   if(g.qty<2)errors.push(`Para klejenia ${pair}: wymagane są co najmniej 2 fizyczne elementy z Etapu 2.`);
   if(g.qty%2!==0)errors.push(`Para klejenia ${pair}: liczba fizycznych elementów (${g.qty}) musi być parzysta — 2 elementy tworzą 1 gotowy element.`);
 });
 return {errors,warnings};
}
function productionPieces(){
 const out=[];
 state.items.forEach((it,itemIndex)=>{
  const p=getProduct(it.productId);if(!p)return;
  const L=n(it.length),W=n(it.width);
  for(let q=1;q<=n(it.qty,1);q++)out.push({id:uid(),itemId:it.id,itemIndex,name:it.name,product:p,length:L,width:W,finishedLength:L,finishedWidth:W,technology:it.technology,gluePair:it.gluePair||"",copy:q,canRotate:!!p.rotatable,placed:null});
 });
 return out;
}
function isNarrowPiece(piece){return Math.min(n(piece.length),n(piece.width))<=NARROW_ELEMENT_MAX_MM}
function pieceOrientations(piece,product){
 const options=[{stripWidth:n(piece.width),runLength:n(piece.length),rotated:false}];
 if(piece.canRotate&&piece.length!==piece.width)options.push({stripWidth:n(piece.length),runLength:n(piece.width),rotated:true});
 return options.filter(o=>o.stripWidth<=n(product.workWidth)+1e-9&&o.runLength<=n(product.workLength)+1e-9);
}
function orientationCapacity(product,o){
 const across=Math.floor((n(product.workWidth)+KERF)/(o.stripWidth+KERF));
 const along=Math.floor((n(product.workLength)+KERF)/(o.runLength+KERF));
 return Math.max(0,across)*Math.max(0,along);
}
function preferredOrientation(piece,product){
 const options=pieceOrientations(piece,product).map(o=>({...o,capacity:orientationCapacity(product,o)}));
 options.sort((a,b)=>b.capacity-a.capacity||a.stripWidth-b.stripWidth||b.runLength-a.runLength);
 return options[0]||null;
}
function binUsedWidth(bin){
 if(!bin.strips.length)return 0;
 return bin.strips.reduce((sum,s)=>sum+s.width,0)+KERF*(bin.strips.length-1);
}
function stripRemainingLength(strip,product){return n(product.workLength)-n(strip.usedLength)}
function canAppendToStrip(strip,o,product){
 if(Math.abs(strip.width-o.stripWidth)>.05)return false;
 const needed=(strip.pieces.length?KERF:0)+o.runLength;
 return needed<=stripRemainingLength(strip,product)+1e-9;
}
function canCreateStrip(bin,o,product){
 const needed=(bin.strips.length?KERF:0)+o.stripWidth;
 return binUsedWidth(bin)+needed<=n(product.workWidth)+1e-9;
}
function placementCandidateScore(candidate){
 return [
  candidate.kind,
  -candidate.capacity,
  candidate.remainingPrimary,
  candidate.remainingSecondary,
  candidate.orientation.stripWidth,
  candidate.binIndex,
  candidate.stripIndex
 ];
}
function lexicographicLess(a,b){
 if(!b)return true;
 const sa=placementCandidateScore(a),sb=placementCandidateScore(b);
 for(let i=0;i<sa.length;i++){
  if(Math.abs(sa[i]-sb[i])>.1e-9)return sa[i]<sb[i];
 }
 return false;
}
function findStripPlacement(bins,piece,product){
 const orientations=pieceOrientations(piece,product);
 let best=null;
 bins.forEach((bin,binIndex)=>{
  orientations.forEach(o=>{
   const capacity=orientationCapacity(product,o);
   bin.strips.forEach((strip,stripIndex)=>{
    if(!canAppendToStrip(strip,o,product))return;
    const needed=(strip.pieces.length?KERF:0)+o.runLength;
    const candidate={kind:0,binIndex,stripIndex,orientation:o,capacity,remainingPrimary:stripRemainingLength(strip,product)-needed,remainingSecondary:n(product.workWidth)-binUsedWidth(bin)};
    if(lexicographicLess(candidate,best))best=candidate;
   });
   if(canCreateStrip(bin,o,product)){
    const needed=(bin.strips.length?KERF:0)+o.stripWidth;
    const candidate={kind:1,binIndex,stripIndex:-1,orientation:o,capacity,remainingPrimary:n(product.workWidth)-binUsedWidth(bin)-needed,remainingSecondary:n(product.workLength)-o.runLength};
    if(lexicographicLess(candidate,best))best=candidate;
   }
  });
 });
 return best;
}
function appendPieceToStrip(bin,strip,piece,o){
 const y=strip.usedLength+(strip.pieces.length?KERF:0);
 strip.pieces.push({piece,y,runLength:o.runLength,rotated:o.rotated});
 strip.usedLength=y+o.runLength;
 bin.used.push(piece);
}
function createStripForPiece(bin,piece,o){
 const strip={width:o.stripWidth,usedLength:0,pieces:[],x:0,narrow:isNarrowPiece(piece)};
 bin.strips.push(strip);
 appendPieceToStrip(bin,strip,piece,o);
}
function stripBlockWidth(strips){return strips.length?strips.reduce((sum,s)=>sum+s.width,0)+KERF*(strips.length-1):0}
function arrangeStripsForNarrowCenter(bin,product){
 const normal=bin.strips.filter(s=>!s.narrow);
 const narrow=bin.strips.filter(s=>s.narrow);
 let ordered=[...bin.strips];
 if(narrow.length){
  const narrowWidth=stripBlockWidth(narrow),boardCenter=n(product.workWidth)/2;
  let bestIndex=0,bestDistance=Infinity;
  for(let i=0;i<=normal.length;i++){
   const left=stripBlockWidth(normal.slice(0,i));
   const start=left+(i>0?KERF:0);
   const center=start+narrowWidth/2;
   const distance=Math.abs(center-boardCenter);
   if(distance<bestDistance){bestDistance=distance;bestIndex=i}
  }
  ordered=[...normal.slice(0,bestIndex),...narrow,...normal.slice(bestIndex)];
 }
 let x=0;
 ordered.forEach((strip,index)=>{
  strip.x=x;
  strip.pieces.forEach(entry=>{
   const piece=entry.piece;
   const actualW=strip.width,actualH=entry.runLength;
   piece.placed={board:bin.no,x,y:entry.y,w:actualW,h:actualH,rotated:entry.rotated,stripOptimized:true,narrowElement:isNarrowPiece(piece),centerPreferenceApplied:isNarrowPiece(piece)};
  });
  x+=strip.width+(index<ordered.length-1?KERF:0);
 });
 bin.strips=ordered;
 bin.usedWidth=stripBlockWidth(ordered);
}
function packGroup(pieces,product){
 // SILNIK 0.7: dwuetapowa optymalizacja gilotynowa pod piłę panelową.
 // 1) elementy tego samego materiału są grupowane w pasy według szerokości cięcia,
 // 2) gotowe pasy są pakowane na arkusze z priorytetem najmniejszego niedomiaru,
 // 3) całość działa na pełnej liście fizycznych elementów, także 2000+ sztuk.
 const oriented=[];
 pieces.forEach(piece=>{
  const o=preferredOrientation(piece,product);
  if(!o)throw new Error(`Element ${piece.name} nie mieści się na produkcie ${product.symbol} ${product.structure}.`);
  oriented.push({piece,stripWidth:o.stripWidth,runLength:o.runLength,rotated:o.rotated});
 });

 // Grupowanie szerokości pasów z tolerancją 0,1 mm.
 const widthGroups=new Map();
 oriented.forEach(entry=>{
  const key=(Math.round(entry.stripWidth*10)/10).toFixed(1);
  if(!widthGroups.has(key))widthGroups.set(key,[]);
  widthGroups.get(key).push(entry);
 });

 const strips=[];
 [...widthGroups.entries()]
  .sort((a,b)=>Number(b[0])-Number(a[0]))
  .forEach(([key,entries])=>{
   entries.sort((a,b)=>b.runLength-a.runLength||b.piece.length*b.piece.width-a.piece.length*a.piece.width||String(a.piece.name).localeCompare(String(b.piece.name),'pl'));
   const local=[];
   entries.forEach(entry=>{
    let bestIndex=-1,bestRemaining=Infinity;
    for(let i=0;i<local.length;i++){
     const strip=local[i];
     const needed=(strip.pieces.length?KERF:0)+entry.runLength;
     const remaining=n(product.workLength)-strip.usedLength-needed;
     if(remaining>=-1e-9&&remaining<bestRemaining){bestRemaining=remaining;bestIndex=i;if(remaining<0.01)break}
    }
    if(bestIndex<0){
     const strip={width:entry.stripWidth,usedLength:0,pieces:[],x:0,narrow:isNarrowPiece(entry.piece)};
     local.push(strip);bestIndex=local.length-1;
    }
    const strip=local[bestIndex];
    const y=strip.usedLength+(strip.pieces.length?KERF:0);
    strip.pieces.push({piece:entry.piece,y,runLength:entry.runLength,rotated:entry.rotated});
    strip.usedLength=y+entry.runLength;
    strip.narrow=strip.narrow||isNarrowPiece(entry.piece);
   });
   strips.push(...local);
  });

 // Pakowanie pasów na arkusze: Best-Fit Decreasing po szerokości pasa.
 strips.sort((a,b)=>b.width-a.width||b.usedLength-a.usedLength);
 const bins=[];
 strips.forEach(strip=>{
  let bestBin=-1,bestRemaining=Infinity;
  for(let i=0;i<bins.length;i++){
   const bin=bins[i];
   const needed=(bin.strips.length?KERF:0)+strip.width;
   const remaining=n(product.workWidth)-binUsedWidth(bin)-needed;
   if(remaining>=-1e-9&&remaining<bestRemaining){bestRemaining=remaining;bestBin=i;if(remaining<0.01)break}
  }
  if(bestBin<0){
   bins.push({no:bins.length+1,strips:[],used:[],product,usedWidth:0});
   bestBin=bins.length-1;
  }
  const bin=bins[bestBin];
  bin.strips.push(strip);
  strip.pieces.forEach(entry=>bin.used.push(entry.piece));
 });

 bins.forEach(bin=>arrangeStripsForNarrowCenter(bin,product));
 verifyPackedBins(bins,product,pieces.length);
 return bins;
}
function verifyPackedBins(bins,product,expectedCount){
 const ids=new Set();let count=0;
 bins.forEach(bin=>{
  if(binUsedWidth(bin)>n(product.workWidth)+0.1)throw new Error(`Kontrola rozkroju: przekroczono szerokość pola roboczego na płycie ${bin.no}.`);
  bin.strips.forEach(strip=>{
   if(strip.usedLength>n(product.workLength)+0.1)throw new Error(`Kontrola rozkroju: przekroczono długość pola roboczego na płycie ${bin.no}.`);
   strip.pieces.forEach(entry=>{
    const piece=entry.piece,r=piece.placed;count++;
    if(ids.has(piece.id))throw new Error(`Kontrola rozkroju: element ${piece.name} został rozmieszczony podwójnie.`);
    ids.add(piece.id);
    if(!r)throw new Error(`Kontrola rozkroju: element ${piece.name} nie otrzymał pozycji.`);
    if(r.x<-0.1||r.y<-0.1||r.x+r.w>n(product.workWidth)+0.1||r.y+r.h>n(product.workLength)+0.1)throw new Error(`Kontrola rozkroju: element ${piece.name} wychodzi poza pole robocze płyty ${bin.no}.`);
   });
  });
 });
 if(count!==expectedCount)throw new Error(`Kontrola rozkroju: rozmieszczono ${count} z ${expectedCount} elementów.`);
}

function roundDim(v){return Math.max(0,Math.round(n(v)*10)/10)}
function wasteRecordId(product,boardNo,type,index){
 const order=(orderNo.value||"BEZ-ZLECENIA").replace(/[^A-Z0-9_-]/gi,"_");
 const material=(product.symbol||"MATERIAL").replace(/[^A-Z0-9_-]/gi,"_");
 return `ODP-${order}-${material}-P${boardNo}-${type}-${index}`;
}
function buildWasteModuleTransfer(groups){
 const records=[];
 groups.forEach(group=>group.bins.forEach(bin=>{
  const p=group.product,fullLength=n(p.length,BOARD_FULL_L),fullWidth=n(p.width,BOARD_FULL_W);
  bin.wasteRecords=[];
  if(!bin.used.length)return;
  const candidates=[];
  const usedWidth=roundDim(bin.usedWidth||stripBlockWidth(bin.strips||[]));
  const sideWidth=roundDim(fullWidth-usedWidth-KERF);
  if(sideWidth>0){
   candidates.push({type:"BOCZNY_PEŁNA_DŁUGOŚĆ",length:roundDim(fullLength),width:sideWidth,rect:{x:roundDim(usedWidth+KERF),y:0,w:sideWidth,h:roundDim(fullLength)},note:"Odpad zachowuje fizyczną długość pełnej płyty 2800 mm; bez brzegowania odpadu."});
  }
  (bin.strips||[]).forEach((strip,stripIndex)=>{
   const endLength=roundDim(fullLength-n(strip.usedLength)-KERF);
   if(endLength>0&&strip.width>0){
    candidates.push({type:"KONIEC_PASA",length:endLength,width:roundDim(strip.width),rect:{x:roundDim(strip.x),y:roundDim(strip.usedLength+KERF),w:roundDim(strip.width),h:endLength},note:`Fizyczny prostokątny odpad na końcu pasa ${stripIndex+1}.`});
   }
  });
  candidates.forEach((c,index)=>{
   const rec={
    id:wasteRecordId(p,bin.no,c.type,index+1),sourceModule:WASTE_SOURCE_MODULE,targetModule:WASTE_TARGET_MODULE,
    category:"PŁYTY",process:"CIĘCIE",orderNo:orderNo.value||"",customer:customer.value||"",orderName:orderName.value||"",
    materialId:p.id,manufacturer:p.manufacturer,material:`${p.symbol} ${p.structure}`,materialName:p.name,thickness:p.thickness,
    sourceBoardNo:bin.no,type:c.type,length:c.length,width:c.width,areaM2:roundDim(c.length*c.width)/1e6,
    rotatable:!!p.rotatable,grainLocked:!p.rotatable,physicalBoard:[fullLength,fullWidth],workArea:[p.workLength,p.workWidth],kerf:KERF,
    physicalDimensions:true,edgeTrimmed:false,currentStatus:WASTE_PLANNED_STATUS,statusAfterCutConfirmation:WASTE_AVAILABLE_STATUS,
    activationEvent:"POTWIERDZENIE_WYKONANIA_CIĘCIA",automaticTransferReady:AUTO_WASTE_MODULE_TRANSFER,requiresPhysicalConfirmation:true,
    note:c.note,rect:c.rect,createdAt:new Date().toISOString()
   };
   bin.wasteRecords.push(rec);records.push(rec);
  });
 }));
 return records;
}

function calculateMetrics(groups){
 const m={finishedM2:0,standardM2:0,productionM2:0,boards:0,edge:{"1MM":0,"2MM":0,"43/2MM":0},hdfSmall:0,hdfLarge:0,ledSmall:0,ledLarge:0,m236:0,m228:0,glue36:0,glue28:0,lamella:0,grain:0};
 state.items.forEach(it=>{
  const qty=n(it.qty,1),L=n(it.length),W=n(it.width),area=L*W*qty/1e6;m.finishedM2+=area;
  if(it.technology==="36MM"){m.m236+=area;m.glue36+=area}
  else if(it.technology==="28MM"){m.m228+=area;m.glue28+=area}
  else m.standardM2+=area;
  const sideLengths={top:W,bottom:W,left:L,right:L};Object.keys(it.edges).forEach(side=>{const t=it.edges[side];if(m.edge[t]!=null)m.edge[t]+=sideLengths[side]*qty/1000});
  const hq=n(it.hdfQty)*qty;if(hq>0){if(n(it.hdfLength)<=1000)m.hdfSmall+=hq;else m.hdfLarge+=hq}
  const lq=n(it.ledQty)*qty;if(lq>0){if(n(it.ledLength)<=1000)m.ledSmall+=lq;else m.ledLarge+=lq}
  m.lamella+=n(it.lamellaCuts)*qty;if(it.isFront)m.grain+=qty;
 });
 groups.forEach(g=>{m.boards+=g.bins.length;m.productionM2+=g.pieces.reduce((sum,p)=>sum+p.length*p.width/1e6,0)});m.pieces=groups.reduce((sum,g)=>sum+g.pieces.length,0);return m;
}
function buildProforma(metrics){return [
 {code:"FORMATKI_STANDARD_M2",name:"Cięcie formatek standardowych",qty:metrics.standardM2,unit:"m²",note:"Fizyczne formatki STANDARD z Etapu 2"},
 {code:"PCV_1MM",name:"Oklejanie PCV 1 MM",qty:metrics.edge["1MM"],unit:"mb",note:"Podział według krawędzi"},
 {code:"PCV_2MM",name:"Oklejanie PCV 2 MM",qty:metrics.edge["2MM"],unit:"mb",note:"Podział według krawędzi"},
 {code:"PCV_43_2MM",name:"Oklejanie PCV 43/2 MM",qty:metrics.edge["43/2MM"],unit:"mb",note:"Elementy 36 MM i 28 MM"},
 {code:"FREZ_HDF_MALY",name:"Frez pod HDF — mały do 1 m",qty:metrics.hdfSmall,unit:"szt.",note:"Długość frezu ≤ 1000 mm"},
 {code:"FREZ_HDF_DUZY",name:"Frez pod HDF — duży powyżej 1 m",qty:metrics.hdfLarge,unit:"szt.",note:"Długość frezu > 1000 mm"},
 {code:"FREZ_LED_MALY",name:"Frez LED — mały do 1 m",qty:metrics.ledSmall,unit:"szt.",note:"Długość frezu ≤ 1000 mm"},
 {code:"FREZ_LED_DUZY",name:"Frez LED — duży powyżej 1 m",qty:metrics.ledLarge,unit:"szt.",note:"Długość frezu > 1000 mm"},
 {code:"FORMATKI_36MM_M2",name:"Fizyczne formatki do elementów 36 MM",qty:metrics.m236,unit:"m²",note:"Suma rzeczywistych elementów z Etapu 2 — bez ponownego mnożenia ×2"},
 {code:"KLEJENIE_36MM_M2",name:"Klejenie elementów 36 MM",qty:metrics.glue36,unit:"m²",note:"Powierzchnia wszystkich fizycznych elementów należących do par klejenia"},
 {code:"FORMATKI_28MM_M2",name:"Fizyczne formatki do elementów 28 MM",qty:metrics.m228,unit:"m²",note:"Suma rzeczywistych elementów z Etapu 2 — bez ponownego mnożenia ×2"},
 {code:"KLEJENIE_28MM_M2",name:"Klejenie elementów 28 MM",qty:metrics.glue28,unit:"m²",note:"Powierzchnia wszystkich fizycznych elementów należących do par klejenia"},
 {code:"ROZCINANIE_LAMELI",name:"Rozcinanie lameli",qty:metrics.lamella,unit:"szt.",note:"Według liczby operacji"},
 {code:"CIECIE_ZE_SLOJA",name:"Cięcie ze słoja",qty:metrics.grain,unit:"front",note:"Liczone od liczby frontów"}
].filter(x=>x.qty>0)}

function renderServicePrices(){
 const host=document.getElementById("servicePriceTable");
 host.innerHTML=SERVICE_DEFS.map(def=>{const price=servicePrices[def.code],ok=n(price)>0;return `<tr><td><b>${esc(def.code)}</b></td><td>${esc(def.name)}</td><td>${esc(def.unit)}</td><td><input class="service-price-input ${ok?"price-ok":"price-missing"}" type="number" min="0" step="0.01" data-service-code="${esc(def.code)}" value="${ok?price:""}" placeholder="PRZYPISZ CENĘ"></td><td>${ok?'<span class="badge green">CENA PRZYPISANA</span>':'<span class="badge red">BRAK CENY</span>'}</td></tr>`}).join("");
}
function applyServicePrices(rows){
 const priced=rows.map(row=>{const price=n(servicePrices[row.code]);return {...row,price:price>0?price:null,value:price>0?row.qty*price:null,priceStatus:price>0?"CENA PRZYPISANA":"BRAK CENY"}});
 return {rows:priced,missing:priced.filter(row=>!row.price)};
}
function showPriceModal(missing){
 document.getElementById("priceModalList").innerHTML=`<b>Brak ceny dla:</b><ul>${missing.map(x=>`<li>${esc(x.code)} — ${esc(x.name)} (${x.unit})</li>`).join("")}</ul>`;
 document.getElementById("priceModal").classList.add("open");
}
function hidePriceModal(){document.getElementById("priceModal").classList.remove("open")}

function svgBoard(bin){
 const p=bin.product,fullW=n(p.width,BOARD_FULL_W),fullH=n(p.length,BOARD_FULL_L),scale=Math.min(690/fullW,690/fullH),w=fullW*scale,h=fullH*scale,pad=38;
 let body=`<rect x="${pad}" y="${pad}" width="${w}" height="${h}" fill="#eef4f8" stroke="#1f4e78" stroke-width="3"/>`;
 body+=`<rect x="${pad}" y="${pad}" width="${p.workWidth*scale}" height="${p.workLength*scale}" fill="none" stroke="#7a8b99" stroke-width="1.5" stroke-dasharray="7 5"/>`;
 (bin.wasteRecords||[]).forEach(waste=>{const r=waste.rect,x=pad+r.x*scale,y=pad+r.y*scale,pw=r.w*scale,ph=r.h*scale;body+=`<rect x="${x}" y="${y}" width="${pw}" height="${ph}" fill="#def3e4" stroke="#2f7d4a" stroke-width="1.6" stroke-dasharray="6 4"/><text x="${x+pw/2}" y="${y+ph/2-3}" text-anchor="middle" font-size="10" font-weight="700">ODPAD</text><text x="${x+pw/2}" y="${y+ph/2+11}" text-anchor="middle" font-size="9">${fmt(waste.length,1)}×${fmt(waste.width,1)}</text>`});
 bin.used.forEach((piece,idx)=>{const r=piece.placed,x=pad+r.x*scale,y=pad+r.y*scale,pw=r.w*scale,ph=r.h*scale;body+=`<rect x="${x}" y="${y}" width="${pw}" height="${ph}" fill="${idx%2?'#fff3d8':'#e6f2ff'}" stroke="#334e68" stroke-width="1.4"/><text x="${x+pw/2}" y="${y+ph/2-4}" text-anchor="middle" font-size="${Math.max(8,Math.min(13,pw/6))}" font-weight="700">${esc(piece.name)}</text><text x="${x+pw/2}" y="${y+ph/2+12}" text-anchor="middle" font-size="10">${piece.length}×${piece.width}${r.rotated?' ↻':''}</text>`});
 return `<svg class="board-svg" viewBox="0 0 ${w+pad*2} ${h+pad*2+22}">${body}<text x="${pad+w/2}" y="${pad+h+19}" text-anchor="middle" font-size="12" font-weight="700">Płyta fizyczna ${p.length} × ${p.width} mm • pole robocze ${p.workLength} × ${p.workWidth} mm</text></svg>`
}
function renderResult(result){
 const m=result.metrics;document.getElementById("kM2").textContent=fmt(m.finishedM2);document.getElementById("kBoards").textContent=m.boards;document.getElementById("kPieces").textContent=fmt(m.pieces,0);document.getElementById("kTime").textContent=`${fmt(result.optimizationMs||0,0)} ms`;document.getElementById("engineStatus").textContent=`Przetworzono ${fmt(m.pieces,0)} elementów • ${m.boards} płyt • ${fmt(result.optimizationMs||0,0)} ms`;document.getElementById("kEdge1").textContent=`${fmt(m.edge["1MM"])} mb`;document.getElementById("kEdge2").textContent=`${fmt(m.edge["2MM"])} mb`;document.getElementById("kEdge43").textContent=`${fmt(m.edge["43/2MM"])} mb`;document.getElementById("k36").textContent=`${fmt(m.m236)} m²`;document.getElementById("k28").textContent=`${fmt(m.m228)} m²`;document.getElementById("kLamella").textContent=`${fmt(m.lamella,0)} szt.`;document.getElementById("kGrain").textContent=`${fmt(m.grain,0)} frontów`;document.getElementById("kWasteCount").textContent=`${result.wasteModuleTransfer.length} szt.`;document.getElementById("kWasteM2").textContent=`${fmt(result.wasteModuleTransfer.reduce((sum,w)=>sum+w.areaM2,0))} m²`;
 document.getElementById("proformaTable").innerHTML=result.proforma.map(x=>`<tr><td>${x.code}</td><td>${x.name}</td><td><b>${x.unit==="m²"||x.unit==="mb"?fmt(x.qty):fmt(x.qty,0)}</b></td><td>${x.unit}</td><td>${x.price?`${fmt(x.price,2)} zł`:"—"}</td><td>${x.value?`<b>${fmt(x.value,2)} zł</b>`:"—"}</td><td>${x.price?'<span class="badge green">CENA PRZYPISANA</span>':'<span class="badge red">BRAK CENY</span>'}</td><td>${x.note}</td></tr>`).join("")||'<tr><td colspan="8">Brak usług wynikowych.</td></tr>';
 document.getElementById("supplierTable").innerHTML=result.groups.map(g=>{const p=g.product,used=g.pieces.reduce((s,x)=>s+x.length*x.width,0),capacity=g.bins.length*p.workLength*p.workWidth,util=capacity?used/capacity*100:0;return `<tr><td>${esc(p.id)}</td><td><b>${esc(p.symbol)} ${esc(p.structure)}</b><br>${esc(p.name)}</td><td>${p.thickness} mm</td><td>${p.length} × ${p.width}</td><td>${p.workLength} × ${p.workWidth}</td><td>${p.rotatable?"OBROTOWA":"NIEOBROTOWA"}</td><td>${fmt(used/1e6)} m²</td><td><b>${g.bins.length}</b></td><td>${fmt(util,1)}%</td><td>${esc(p.priceStatus)}</td></tr>`}).join("");
 document.getElementById("layouts").innerHTML=result.groups.map(g=>{const shown=g.bins.slice(0,MAX_BOARD_PREVIEW),hidden=Math.max(0,g.bins.length-shown.length);return `<div class="material-result"><div class="material-head"><div><h3>${esc(g.product.symbol)} ${esc(g.product.structure)} — ${g.product.thickness} mm</h3><div class="note">${esc(g.product.name)} • ${g.product.rotatable?"OBROTOWA":"NIEOBROTOWA"}</div></div><span class="badge blueb">${g.bins.length} płyt</span></div>${hidden?`<div class="warn-box">Podgląd pokazuje pierwsze ${shown.length} z ${g.bins.length} płyt. Pełny rozkrój znajduje się w wyniku JSON.</div>`:""}<div class="board-grid">${shown.map(bin=>`<div class="board-card"><h4>PŁYTA ${bin.no}</h4><div class="board-meta">Elementy: ${bin.used.length} • rzaz 4,4 mm • optymalizacja pasowa • wąskie ≤ 100 mm: ${bin.used.filter(isNarrowPiece).length} • planowane odpady: ${(bin.wasteRecords||[]).length}</div>${svgBoard(bin)}</div>`).join("")}</div></div>`}).join("");
 document.getElementById("wasteTable").innerHTML=result.wasteModuleTransfer.slice(0,MAX_WASTE_PREVIEW).map(w=>`<tr><td><b>${esc(w.id)}</b></td><td>${esc(w.orderNo)}<br>${esc(w.customer)}</td><td><b>${esc(w.material)}</b><br>${esc(w.materialName)}</td><td>${w.thickness} mm</td><td>PŁYTA ${w.sourceBoardNo}</td><td>${esc(w.type)}</td><td><b>${fmt(w.length,1)} × ${fmt(w.width,1)} mm</b><br><span class="note">pełna płyta ${w.physicalBoard[0]} × ${w.physicalBoard[1]}</span></td><td>${fmt(w.areaM2)} m²</td><td>${w.rotatable?"OBROTOWY":"NIEOBROTOWY / SŁÓJ"}</td><td><span class="badge yellow">${esc(w.currentStatus)}</span></td><td><span class="badge green">${esc(w.statusAfterCutConfirmation)}</span></td></tr>`).join("")||'<tr><td colspan="11">Brak prostokątnych odpadów do przekazania.</td></tr>';
 const placementById=new Map();result.groups.forEach(g=>g.bins.forEach(b=>b.used.forEach(p=>placementById.set(p.id,p.placed))));
 const previewPieces=result.groups.flatMap(g=>g.pieces).slice(0,MAX_PIECE_PREVIEW);document.getElementById("piecesTable").innerHTML=previewPieces.map(p=>{const r=placementById.get(p.id);return `<tr><td>${esc(p.name)} / ${p.copy}</td><td>${esc(p.product.symbol)} ${esc(p.product.structure)}</td><td>${p.product.thickness}</td><td>${p.finishedLength} × ${p.finishedWidth}</td><td>${p.technology}${p.gluePair?`<br><span class="badge orange">${esc(p.gluePair)}</span>`:""}${isNarrowPiece(p)?`<br><span class="badge blueb">≤ 100 MM — ŚRODEK, JEŚLI MOŻLIWE</span>`:""}</td><td><b>${p.length} × ${p.width}</b></td><td>1</td><td>${r?.board||"—"}</td><td>${r?`${fmt(r.x,1)} / ${fmt(r.y,1)}`:"—"}</td><td>${r?.rotated?"TAK":"NIE"}</td></tr>`}).join("");
}
function optimize(showMissingModal=true){
 const started=performance.now();
 const v=validate(),val=document.getElementById("validation");
 document.getElementById("engineStatus").textContent="Optymalizacja w toku…";
 if(v.errors.length){val.innerHTML=`<div class="error-box"><b>NIEPRAWIDŁOWE INFORMACJE — PROSZĘ O WERYFIKACJĘ ADMINISTRATORA</b><ul>${v.errors.map(x=>`<li>${esc(x)}</li>`).join("")}</ul></div>${v.warnings.length?`<div class="warn-box"><ul>${v.warnings.map(x=>`<li>${esc(x)}</li>`).join("")}</ul></div>`:""}`;state.lastResult=null;clearResults();return}
 try{
  const pieces=productionPieces(),map=new Map();pieces.forEach(piece=>{if(!map.has(piece.product.id))map.set(piece.product.id,{product:piece.product,pieces:[]});map.get(piece.product.id).pieces.push(piece)});
  const groups=[...map.values()].map(g=>({...g,bins:packGroup(g.pieces,g.product)}));
  const wasteModuleTransfer=buildWasteModuleTransfer(groups),metrics=calculateMetrics(groups),priced=applyServicePrices(buildProforma(metrics));
  const optimizationMs=performance.now()-started;
  state.lastResult={groups,metrics,wasteModuleTransfer,proforma:priced.rows,missingServicePrices:priced.missing,priceComplete:priced.missing.length===0,optimizationMs,createdAt:new Date().toISOString()};
  renderResult(state.lastResult);
  emitHostResult();
  if(priced.missing.length){val.innerHTML=`<div class="error-box"><b>ROZKRÓJ WYKONANY — FINALNA PROFORMA ZABLOKOWANA</b><br>PROSZĘ PRZYPISAĆ CENĘ USŁUGI.<ul>${priced.missing.map(x=>`<li>${esc(x.code)} — ${esc(x.name)}</li>`).join("")}</ul></div>${v.warnings.length?`<div class="warn-box" style="margin-top:8px"><ul>${v.warnings.map(x=>`<li>${esc(x)}</li>`).join("")}</ul></div>`:""}`;if(showMissingModal)showPriceModal(priced.missing)}
  else{hidePriceModal();val.innerHTML=`<div class="ok-box"><b>Dane spójne, ceny usług przypisane — rozkrój i proforma gotowe.</b></div>${v.warnings.length?`<div class="warn-box" style="margin-top:8px"><ul>${v.warnings.map(x=>`<li>${esc(x)}</li>`).join("")}</ul></div>`:""}`}
 }catch(err){val.innerHTML=`<div class="error-box"><b>Błąd optymalizacji:</b> ${esc(err.message)}</div>`;state.lastResult=null;clearResults()}
}
function clearResults(){["kM2","kBoards","kPieces"].forEach(id=>document.getElementById(id).textContent="0");document.getElementById("kTime").textContent="0 ms";document.getElementById("engineStatus").textContent="Silnik gotowy: 0 elementów";document.getElementById("kEdge1").textContent="0,000 mb";document.getElementById("kEdge2").textContent="0,000 mb";document.getElementById("kEdge43").textContent="0,000 mb";document.getElementById("k36").textContent="0,000 m²";document.getElementById("k28").textContent="0,000 m²";document.getElementById("kLamella").textContent="0 szt.";document.getElementById("kGrain").textContent="0 frontów";document.getElementById("kWasteCount").textContent="0 szt.";document.getElementById("kWasteM2").textContent="0,000 m²";document.getElementById("wasteTable").innerHTML="";document.getElementById("proformaTable").innerHTML="";document.getElementById("supplierTable").innerHTML="";document.getElementById("layouts").innerHTML='<div class="note">Brak wyników.</div>';document.getElementById("piecesTable").innerHTML=""}
function payload(){return {version:"KMS KREATOR ROZKROJU TEST 0.8 INTEGRATED",constants:{boardFull:[BOARD_FULL_L,BOARD_FULL_W],boardWork:[BOARD_WORK_L,BOARD_WORK_W],kerf:KERF,narrowElementMaxMm:NARROW_ELEMENT_MAX_MM,stripOptimization:STRIP_OPTIMIZATION,reusableOffcutPriority:REUSABLE_OFFCUT_PRIORITY,physicalWasteFromFullBoard:PHYSICAL_WASTE_FROM_FULL_BOARD,automaticWasteModuleTransfer:AUTO_WASTE_MODULE_TRANSFER,wasteLifecycle:"PLANOWANY po optymalizacji; DO WYKORZYSTANIA po potwierdzeniu wykonania cięcia",stripRule:"Dla materiału obrotowego porównaj obie orientacje; buduj pasy wzdłuż 2800 mm i zachowaj największy prostokątny odpad",wasteRule:"Odpad fizyczny licz z pełnej płyty 2800 × 2070 mm; odpad boczny zachowuje długość 2800 mm i nie jest brzegowany",narrowPlacementRule:"W miarę możliwości pośrodku pola roboczego płyty; bez kolizji, zmiany orientacji i zwiększania liczby płyt",gluingRule:"Etap 2 przekazuje fizyczne elementy; bez ponownego mnożenia x2"},order:{orderNo:orderNo.value,customer:customer.value,orderName:orderName.value,date:orderDate.value,operator:operator.value},catalogSnapshot:catalog,servicePrices,items:state.items,result:state.lastResult?{metrics:state.lastResult.metrics,proforma:state.lastResult.proforma,priceComplete:state.lastResult.priceComplete,missingServicePrices:state.lastResult.missingServicePrices,wasteModuleTransfer:state.lastResult.wasteModuleTransfer,supplierOrder:state.lastResult.groups.map(g=>({catalogProductId:g.product.id,material:`${g.product.symbol} ${g.product.structure}`,thickness:g.product.thickness,fullFormat:[g.product.length,g.product.width],workArea:[g.product.workLength,g.product.workWidth],rotatable:g.product.rotatable,boards:g.bins.length,productionM2:g.pieces.reduce((sum,p)=>sum+p.length*p.width/1e6,0)})),layouts:state.lastResult.groups.map(g=>({catalogProductId:g.product.id,boards:g.bins.map(b=>({boardNo:b.no,pieces:b.used.map(p=>({name:p.name,length:p.length,width:p.width,technology:p.technology,gluePair:p.gluePair,x:p.placed.x,y:p.placed.y,rotated:p.placed.rotated,stripOptimized:!!p.placed.stripOptimized,narrowElement:isNarrowPiece(p),centerPreferenceApplied:!!p.placed.centerPreferenceApplied})),plannedWaste:(b.wasteRecords||[]).map(w=>({id:w.id,type:w.type,length:w.length,width:w.width,areaM2:w.areaM2,currentStatus:w.currentStatus,statusAfterCutConfirmation:w.statusAfterCutConfirmation}))}))}))}:null}}
